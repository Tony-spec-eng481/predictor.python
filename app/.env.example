# ============================================================
# Environment variables — copy to .env and fill in your values
# ============================================================

# Flask environment: development | production | testing
FLASK_ENV=production

# A long random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploy

# Database — leave blank to use SQLite (default)
# For Postgres: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Comma-separated list of allowed CORS origins for the API
# e.g. https://your-frontend.vercel.app,https://yoursite.com
# Use * to allow all (not recommended for production)
CORS_ORIGINS=https://predictor-seven-pi.vercel.app/

# Server bind settings (used by Gunicorn via wsgi.py)
HOST=0.0.0.0
PORT=5000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
